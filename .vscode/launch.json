{
	// Use IntelliSense to learn about possible attributes.
	// Hover to view descriptions of existing attributes.
	// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
	"version": "0.2.0",
	    "configurations": [
        {
            "name": "Flutter Web (chrome-port-54321)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "args": [
                "-d",
                "chrome",
                "--web-port=54321",
                "--dart-define-from-file=dart_defines.json"
            ]
        },
		{
			"name": "cardcompass",
			"request": "launch",
			"type": "dart",
			"args": [
				"--dart-define-from-file=dart_defines.json"
			]
		},
		{
			"name": "cardcompass (profile mode)",
			"request": "launch",
			"type": "dart",
			"flutterMode": "profile",
			"args": [
				"--dart-define-from-file=dart_defines.json"
			]
		},
		{
			"name": "cardcompass (release mode)",
			"request": "launch",
			"type": "dart",
			"flutterMode": "release",
			"args": [
				"--dart-define-from-file=dart_defines.json"
			]
		}
	]
}
